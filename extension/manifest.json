{
  "manifest_version": 3,
  "name": "CrunchyList",
  "version": "1.0.0",
  "description": "Parent-curated, kid-safe front end for Crunchyroll. Only whitelisted shows are visible.",
  "permissions": [
    "storage",
    "webNavigation"
  ],
  "host_permissions": [
    "*://*.crunchyroll.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.crunchyroll.com/*"],
      "css": ["content.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.crunchyroll.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "chrome_url_overrides": {
    "newtab": "landing.html"
  },
  "action": {
    "default_popup": "landing.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
